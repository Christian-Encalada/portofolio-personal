# 1. Crea tu access key gratis en https://web3forms.com (email: example@gmail.com)
# 2. Copia este archivo como ".env" y pega tu key abajo
# 3. Reinicia el servidor: npm run dev

VITE_WEB3FORMS_ACCESS_KEY=tu_access_key_aqui

# En Vercel (producción) usa esta variable en Settings → Environment Variables:
# WEB3FORMS_ACCESS_KEY=tu_access_key_aqui
